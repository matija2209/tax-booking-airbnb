AIRBNB_EMAIL=your_email@example.com
AIRBNB_PASSWORD=your_password

BOOKING_EMAIL=your_email@example.com
BOOKING_PASSWORD=your_password

# Set to your Booking.com hotel ID(s) if auto-detection fails.
# Multiple IDs: BOOKING_HOTEL_ID=12345,67890
BOOKING_HOTEL_ID=

# Set to false to run in headed (visible) mode for development/debugging.
# Set DEVTOOLS=true to also open Chrome DevTools automatically.
HEADLESS=false
DEVTOOLS=false

# Output directory for CSV files
# OUTPUT_DIR=./output
